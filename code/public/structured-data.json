          "@type": "Question",
          "name": "Is RunwayHub free to use?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "Yes! RunwayHub is completely free and open-source. You can self-host it or use our public instance at no cost."
          }
        },
        {
          "@type": "Question",
          "name": "What data sources does RunwayHub support?",
          "acceptedAnswer": {
            "@type": "Answer",
            "text": "RunwayHub supports OpenAIP, FlightAware, Eurocontrol, ADS-B, and many more aviation data sources. All data is aggregated and presented in one place."
          }
        },
        {
          "@type": "Question",
          "name": "Can I self-host RunwayHub?",
          "acceptedAnswer": {
            "@type": "Answer",
