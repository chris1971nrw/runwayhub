{
    "name": "chris1971nrw/runwayhub",
    "description": "Modernes Virtual Airline Management System für Flugsimulation mit Multi-Airline Support, Live-Flugverfolgung, Wetter-API und ACARS Integration",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Chris 1971 NRW",
            "email": "chris1971nrw@ab.de",
            "role": "Developer"
        }
    ],
    "minimum-stability": "stable",
    "require": {
        "php": ">=8.3",
        "vlucas/phpdotenv": "^5.6",
        "monolog/monolog": "^3.5",
        "ramsey/uuid": "^4.7",
        "php-amqplib/php-amqplib": "^3.7"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5",
        "phpstan/phpstan": "^1.10",
        "roave/security-advisories": "dev-latest"
    },
    "autoload": {
        "psr-4": {
            "RunwayHub\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "lint": "phpcs",
        "stan": "phpstan analyse"
    },
    "config": {
        "allow-plugins": {
            "php-http/discovery": true
        }
    }
}
