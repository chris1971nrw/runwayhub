APP_NAME=RunwayHub
APP_PORT=8080

# Datenbank
DB_PATH=/app/database.sqlite

# SMTP Email
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_smtp_user
SMTP_PASS=your_smtp_password
SMTP_SECURE=false
MAILER_DOMAIN=runwayhub.example.com

# Admin
ADMIN_EMAIL=admin@example.com

# Features
NOTIFICATIONS_ENABLED=true
ALLOW_REGISTRATION=false
ALLOW_BOOKING=false
ALLOW_ADMIN=false

# ACARS API (Optional)
ACARS_API_URL=https://api.runwayhub.example/acars
ACARS_API_KEY=your_acars_api_key

# Wetter API
WEATHER_PROVIDER=openmeteo
WEATHER_CACHE_TTL=300

# Limitierungen
MAX_BOOKINGS_PER_USER=100

# Sicherheit
ALLOWED_HOSTS=localhost,127.0.0.1,runwayhub.example.com
SESSION_LIFETIME=7200

# Debug
APP_DEBUG=false
APP_ENV=production
