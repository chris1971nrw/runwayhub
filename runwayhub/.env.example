APP_NAME=RunwayHub
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_TIMEZONE=Europe/Berlin
APP_LOCALE=de_DE

# Demo-System Einstellungen
APP_MODE=demo  # demo | production
APP_DEMO_MODE=false  # true = Demo-System, false = Hauptsystem
APP_DEMO_AIRLINE_ID=1  # Demo Airline ID

# GitHub für Issues
GITHUB_TOKEN=
GITHUB_OWNER=chris1971nrw
GITHUB_REPO=runwayhub
GITHUB_REPO_DEMO=runwayhub-demo

# API Keys
OPENAIP_API_KEY=4eafd2e1740e235b937c362c0e3074f9
OPENAIP_CACHE_TTL=3600

# Datenbank
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=runwayhub
DB_USERNAME=runwayhub
DB_PASSWORD=your_password

# Synchronisation
DEMO_SYNC_ENABLED=true  # Synchronise Demo mit Hauptsystem
DEMO_SYNC_BRANCH=main   # Branch für Synchronisation
DEMO_SYNC_TAGS=bug,demo  # Tags für Demo-Issues

# Logging
LOG_CHANNEL=stack
LOG_DEMO=true  # Demo-Log separat

# Cache
CACHE_DRIVER=file
SESSION_DRIVER=file
QUEUE_DRIVER=sync

# Storage
QUEUE_CONNECTION=sync

# OpenAIP
OPENAIP_DEMO=true
