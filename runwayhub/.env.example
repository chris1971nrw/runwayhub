# RunwayHub Environment Variables
# Kopieren Sie diese Datei und passen Sie die Werte an

# Datenbank
DB_HOST=localhost
DB_PORT=3306
DB_DATABASE=runwayhub
DB_USER=runwayhub_user
DB_PASSWORD=runwayhub_password

# OpenAIP API
OPENAIP_API_KEY=4eafd2e1740e235b937c362c0e3074f9
OPENAIP_API_URL=https://www.openaip.net

# API Limits
OPENAIP_API_LIMIT=1000
OPENAIP_API_CACHE_TTL=300

# Sync Konfiguration
OPENAIP_SYNC_INTERVAL=86400  # 24 Stunden in Sekunden
OPENAIP_SYNC_FORCE=false

# Debug
DEBUG=true
LOG_LEVEL=info
