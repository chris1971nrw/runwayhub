# RunwayHub Environment Variables
# Copy this file to .env and configure for your environment

# Application
APP_NAME=RunwayHub
APP_ENV=local
APP_DEBUG=false
APP_URL=https://runwayhub.de

# Database
DB_HOST=localhost
DB_PORT=3306
DB_NAME=runwayhub
DB_USER=runwayhub
DB_PASS=runwayhub_password
DB_CHARSET=utf8mb4

# Session
SESSION_NAME=runwayhub_session
SESSION_LIFETIME=7200
SESSION_SECURE=false
SESSION_HTTPONLY=true
SESSION_SAMESITE=Lax

# Cache
CACHE_DRIVER=file
CACHE_PREFIX=runwayhub_

# Queue
QUEUE_CONNECTION=sync

# Mail
MAIL_DRIVER=smtp
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@runwayhub.de
MAIL_FROM_NAME=RunwayHub

# API Keys
FLIGHT_AWARE_API_KEY=
WEATHER_API_KEY=
STRIPE_PUBLIC_KEY=
STRIPE_SECRET_KEY=

# SMTP (optional)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_ENCRYPTION=tls

# Redis (optional)
REDIS_HOST=
REDIS_PORT=6379

# OTA Integration (optional)
AMADEUS_API_KEY=
SABRE_API_KEY=
TRAVELPORT_API_KEY=
