plugin-skills/
plugin-state/
plugins/
session-delivery-queue/
subagents/
tasks/
workspace/
workspace-*/
memory/
memories/
memory/*.md
*.jsonld
*heartbeat-state.json
*.jsonld/*

# Environment
.env
.env.local

# Database
*.sqlite
*.db

# Logs
*.log
logs/

# IDE
.idea/
.vscode/
*.swp
*.swo

# Uploads
uploads/*
